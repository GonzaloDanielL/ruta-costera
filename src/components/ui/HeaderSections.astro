---
interface Props {
    title: string;
    subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<header class="flex flex-col items-center mb-12 max-w-7xl xl:mb-20">
    <h2
        class="text-sm font-semibold text-gray-600 rounded-full px-5 py-2 bg-gray-100 border border-gray-400 lg:text-base"
    >
        {title}
    </h2>
    <p class="text-2xl text-center font-semibold mt-4 text-gray-800 lg:text-3xl">
        {subtitle}
    </p>
</header>
