---
interface Props {
    title: string;
    subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<header class="flex flex-col items-center mb-12">
    <h2
        class="text-sm font-semibold text-gray-600 rounded-full px-5 py-2 bg-gray-100 border border-gray-400"
    >
        {title}
    </h2>
    <p class="text-2xl text-center font-bold mt-4 text-gray-800">
        {subtitle}
    </p>
</header>
