---
import { Image } from "astro:assets";
import itinerario from "../../data/datos.json";
import HeaderSections from "../ui/HeaderSections.astro";
import imgParacas2 from "../../assets/galeria/paracas-2.jpg";
import imgIslasBallestas4 from "../../assets/galeria/islas-ballestas-4.jpg";
import imgHuacachina2 from "../../assets/galeria/huacachina-2.jpg";
import imgHuacachina3 from "../../assets/galeria/huacachina-3.jpg";
---

<section
    id="itinerario"
    class="flex flex-col justify-center items-center bg-gray-50 px-6 py-20 md:px-12 xl:py-40"
>
    <!-- Header itinerario -->
    <HeaderSections
        title="Itinerario"
        subtitle="Un viaje lleno de aventuras."
    />
    <!-- end Header itinerario -->

    <!-- itinerario -->
    <div class="flex flex-row gap-7 max-w-7xl w-full">
        <!-- Timeline -->
        <div class="flex-2/4 xl:flex-2/3">
            <!-- Item -->
            {
                itinerario.itinerario.map((item) => (
                    <div class="flex gap-x-2">
                        {/*                     <div class="min-w-14 text-end">
                        <span class="text-xs text-gray-900">{item.hora}</span>
                    </div> */}

                        <div class="relative last:after:hidden after:absolute after:top-7 after:bottom-0 after:start-3.5 after:w-px after:-translate-x-[0.5px] after:bg-gray-400">
                            <div class="relative z-10 size-7 flex justify-center items-center">
                                <div class="size-2 rounded-full bg-amber-300 pulse-animation" />
                                <div class="absolute size-2 rounded-full bg-amber-300" />
                            </div>
                        </div>

                        <div class="grow pt-0.5 pb-8">
                            <span class="px-3 py-2 text-xs rounded-lg font-semibold text-gray-800 bg-amber-300">
                                {item.hora}
                            </span>
                            <h3 class="mt-4 flex gap-x-1.5 rounded-lg font-medium text-lg text-gray-800">
                                {item.titulo}
                            </h3>
                            <p class="mt-1 mb-1 text-base text-gray-600">
                                {item.descripcion}
                            </p>
                        </div>
                    </div>
                ))
            }
            <!-- End Item -->
        </div>
        <!-- End Timeline -->
        <!-- imagenes -->
        <div class="flex-2/4 hidden lg:flex flex-col items-center xl:flex-2/6">
            <div
                class="mt-10 relative transform rotate-45 w-60 h-60 overflow-hidden flex justify-center items-center shadow-lg shadow-gray-500/40 rounded-xl" 
            >
                <Image
                    class="absolute transform -rotate-45 scale-150 object-cover"
                    src={imgParacas2}
                    alt="Ciudad de Paracas"
                    width={360}
                    height={360}
                    format="webp"
                    quality={90}
                />
            </div>
            <div
                class="ml-60 relative transform rotate-45 w-40 h-40 overflow-hidden flex justify-center items-center shadow-lg shadow-gray-500/40 rounded-xl xl:ml-70"
            >
                <Image
                    class="absolute transform -rotate-45 scale-200 object-cover"
                    src={imgIslasBallestas4}
                    alt="Islas Ballestas, pingüinos de humboldt"
                    width={320}
                    height={320}
                    format="webp"
                    quality={90}
                />
            </div>
            <div
                class="relative transform rotate-45 w-50 h-50 overflow-hidden flex justify-center items-center shadow-lg shadow-gray-500/40 rounded-xl xl:w-30 xl:h-30"
            >
                <Image
                    class="absolute transform -rotate-45 scale-150 object-cover"
                    src={imgHuacachina2}
                    alt="Atardecer en Huacachina"
                    width={300}
                    height={300}
                    format="webp"
                    quality={90}
                />
            </div>
            <div
                class="ml-60 relative transform rotate-45 w-30 h-30 overflow-hidden flex justify-center items-center shadow-lg shadow-gray-500/40 rounded-xl xl:ml-70 xl:w-30 xl:h-30 xl:hidden" 
            >
                <Image
                    class="absolute transform -rotate-45 scale-150 object-cover"
                    src={imgHuacachina3}
                    alt="Sandboard en Huacachina"
                    width={180}
                    height={180}
                    format="webp"
                    quality={90}
                />
            </div>
        </div>
    </div>
</section>
