---
import HeaderSections from "../ui/HeaderSections.astro";
---

<section
    id="venta"
    class="flex flex-col justify-center items-center bg-gray-200 px-6 py-20 md:px-12 xl:py-40"
>
    <!-- Header Venta -->
    <HeaderSections
        title="Venta"
        subtitle="¡Aprovecha la Promoción de Temporada!"
    />
    <!-- end Header Venta -->

    <!-- Venta -->
    <div class="flex flex-col items-center max-w-7xl">
        <p class="relative bg-amber-300 font-bold text-6xl px-5 py-4 rounded-xl transform -rotate-4 shadow-lg shadow-amber-200 xl:text-8xl">S/99.00</p>
        <span class="mt-4 relative flex flex-col items-center transform font-medium text-gray-400 text-4xl">
            <div class="absolute top-3/6 bg-red-400 w-40 h-0.5 transform -rotate-6"></div>
            S/150.00</span>
        <p class="mt-4 mb-5 flex flex-col items-center">
            <span class="text-xl font-medium text-gray-800">¡Gran oferta!</span>
            <span class="text-sm text-gray-500">Por persona</span>
        </p>
        <a
            href="https://chalo-portafolio.vercel.app/"
            target="_blank"
            rel="noreferrer"
            class="flex items-center w-fit gap-2 bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-6 rounded-lg transition-all duration-300 ease-in-out transform hover:scale-105"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4"
                viewBox="0 0 16 16"
                ><path
                    fill="currentColor"
                    d="M13.95 4.24C11.86 1 7.58.04 4.27 2.05C1.04 4.06 0 8.44 2.09 11.67l.17.26l-.7 2.62l2.62-.7l.26.17c1.13.61 2.36.96 3.58.96c1.31 0 2.62-.35 3.75-1.05c3.23-2.1 4.19-6.39 2.18-9.71Zm-1.83 6.74c-.35.52-.79.87-1.4.96c-.35 0-.79.17-2.53-.52c-1.48-.7-2.71-1.84-3.58-3.15c-.52-.61-.79-1.4-.87-2.19c0-.7.26-1.31.7-1.75c.17-.17.35-.26.52-.26h.44c.17 0 .35 0 .44.35c.17.44.61 1.49.61 1.58c.09.09.05.76-.35 1.14c-.22.25-.26.26-.17.44c.35.52.79 1.05 1.22 1.49c.52.44 1.05.79 1.66 1.05c.17.09.35.09.44-.09c.09-.17.52-.61.7-.79c.17-.17.26-.17.44-.09l1.4.7c.17.09.35.17.44.26c.09.26.09.61-.09.87Z"
                ></path></svg
            >
            Comprar
        </a>
    </div>
</section>
